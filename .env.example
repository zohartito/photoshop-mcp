# Optional: disable anonymous usage analytics
# POSTHOG_DISABLED=1

# Beta team content sharing (prompts/responses) is controlled via the UI consent
# modal and Settings → Privacy — there is no separate env flag.

# Optional: override PostHog configuration (maintainers / self-hosted builds)
# POSTHOG_KEY=phc_your_project_key
# POSTHOG_API_HOST=https://a.alisait.com
# POSTHOG_UI_HOST=https://eu.posthog.com

# Existing server options
# PHOTOSHOP_PATH=/Applications/Adobe Photoshop 2025/Adobe Photoshop 2025.app/Contents/MacOS/Adobe Photoshop 2025
# LOG_LEVEL=1
